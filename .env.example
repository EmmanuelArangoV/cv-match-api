# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres.[project-ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Redis (Upstash — TLS)
REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=riwi-match
R2_PUBLIC_URL=

# OpenAI
OPENAI_API_KEY=

# Twilio (llamadas de profiling)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_API_URL=https://api.twilio.com
TWILIO_VALIDATE_SIGNATURE=true

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_BASE_URL=
ELEVENLABS_WEBHOOK_SECRET_TRANSCRIPTION=

# URL publica de este backend (ngrok en dev) para que Twilio/ElevenLabs entreguen webhooks
PUBLIC_BASE_URL=

# Meta WhatsApp Business
META_WHATSAPP_API_URL=https://graph.facebook.com/v21.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_WEBHOOK_SECRET=
# true mientras 'autorizacion_llamada_ia_v2' esta en revision -> manda 'hello_world' en su lugar
WHATSAPP_TEMPLATE_FALLBACK_ENABLED=false

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Business rules
MAX_CONCURRENT_CALLS=4
WHATSAPP_CONSENT_TIMEOUT_HOURS=24
CV_BATCH_LIMIT=50
MAX_CALL_ATTEMPTS=3
MACHINE_DETECTION_TIMEOUT=10
TWILIO_RING_TIMEOUT_SECONDS=25

# Watchdog: reintenta/marca FAILED los ProfilingRun atascados en CALLING/ANSWERED
# sin webhook de cierre (Twilio status o ElevenLabs post-call) — requiere celery beat corriendo
WATCHDOG_INTERVAL_SECONDS=120
STALE_CALLING_TIMEOUT_SECONDS=60
STALE_ANSWERED_TIMEOUT_SECONDS=900
